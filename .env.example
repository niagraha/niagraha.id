# Copy this file to .env for local `vercel dev`, or set these in
# Vercel Project Settings -> Environment Variables for production.
# NEVER commit a populated .env — it is gitignored.

# Resend API key (https://resend.com/api-keys). Server-side only.
# Stay on the free tier while you're under 3,000 emails/month.
RESEND_API_KEY=

# Optional: a Resend Audience ID to add subscribers to a list.
# If left blank, the handler instead sends a notification email to
# the team address (set TEAM_NOTIFY_EMAIL below).
RESEND_AUDIENCE_ID=

# Used only when RESEND_AUDIENCE_ID is blank.
# The address that receives a "new signup" notification.
TEAM_NOTIFY_EMAIL=hello@niagraha.id

# Verified sending domain on Resend (e.g. "notify.niagraha.id").
# Used as the From: address for any email this function sends.
RESEND_FROM_ADDRESS=niagraha <notify@niagraha.id>
